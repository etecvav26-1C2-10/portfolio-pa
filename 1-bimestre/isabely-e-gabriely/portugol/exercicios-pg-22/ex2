*Descrição: Ler três números e verificar se eles formam um triângulo. Caso formem, identificar se é equilátero, isósceles ou escaleno
*/
programa
{
	
	funcao inicio()
	{
		real a, b, c

		escreva("Digite o valor do lado A: ")
		leia(a)
		
		escreva("Digite o valor do lado B: ")
		leia(b)
		
		escreva("Digite o valor do lado C: ")
		leia(c)

		limpa()

		se (a < b + c e b < a + c e c < a + b) 
		{
			escreva("Os lados formam um triângulo: ")

			// Classificação quanto aos lados
			se (a == b e b == c) 
			{
				escreva("EQUILÁTERO\n")
				escreva("Pois todos os lados são iguais.")
			}
			senao se (a == b ou a == c ou b == c) 
			{
				escreva("ISÓSCELES\n")
				escreva("Pois dois lados são iguais.")
			}
			senao 
			
			{
				escreva("ESCALENO\n")
				escreva("Pois todos os lados são diferentes.")
			}
		}

	}
}
