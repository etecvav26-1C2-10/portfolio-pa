*Descrição: Ler um caractere e verificar se ele é uma vogal. Exibir o caractere informado e indicar se é ou não uma vogal.
*/
programa
{
	
	funcao inicio()
	{
		caracter letra

		escreva("Escreva uma letra:\n")
		leia(letra)

		se (letra == 'a' ou letra == 'e' ou letra == 'i' ou letra == 'o' ou letra == 'u') {
			escreva("A letra é uma vogal")
		}
	     senao {
	     	escreva("A letra não é uma vogal")
	     }
	 }
}
