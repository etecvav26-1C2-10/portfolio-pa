*Descrição: Ler um número e verificar se ele é um quadrado perfeito.
*/
programa
{
inclua biblioteca Matematica --> mat
	
	funcao inicio()
	{
   
inteiro numero
real  raiz

escreva ("Digite um numero\n")
leia(numero)
limpa()

raiz = Matematica.raiz(numero, 2.0)

se (raiz == mat.arredondar(raiz, 0)) {
   escreva(numero, " é uma raiz perfeita")
}
senao {
   escreva(numero, " não é uma raiz perfeita")
}
	  
	}
	
}
