programa
{
	
	funcao inicio()
	{
		inteiro idade

		escreva("Qual a idade do passageiro?\n")
		leia(idade)

		se (idade <= 2) {
			escreva("A passagem é gratuita")
		}
		senao se (idade <= 12) {
			escreva("A passagem é meia")
		}
		senao {
			escreva("O valor da passagem é inteiro")
		}
	}
}
